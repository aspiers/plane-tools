# Plane API access (https://api.plane.so by default; self-hosted users
# can override). Get the API token from Plane: Settings -> API tokens.
PLANE_API_TOKEN=plane_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLANE_WORKSPACE_SLUG=your-workspace-slug
PLANE_BASE_URL=https://api.plane.so

# GitHub access. Either set GITHUB_TOKEN here, or rely on the gh CLI
# (the script falls back to `gh auth token` if GITHUB_TOKEN is unset).
# Required scopes: repo (read access to the issues you're mirroring).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
